# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored — never commit real keys/tokens.

# Mapbox access token for the coverage map (public — exposed to the browser).
NEXT_PUBLIC_MAPBOX_TOKEN=

# Pixabay API key used by `scripts/fetch-stock.sh` to fetch self-hosted stock
# imagery (garden / team / winter slots). Server-only; never exposed to the client.
# Usage: set it here, then `set -a; . ./.env.local; set +a; bash scripts/fetch-stock.sh`
PIXABAY_KEY=
